# Direct Primary Connection (Bypasses PgBouncer, rarely used by apps)
PG_ACTUAL_HOST=trading-db-rw.data.svc.cluster.local
PG_ACTUAL_PORT=5432

# Read/Write Operations (Routes to Primary via PgBouncer)
PG_ROUTING_HOST=trading-pooler.data.svc.cluster.local
PG_ROUTING_PORT=5432

# Read-Only Operations (Routes to Replicas via PgBouncer)
PG_RO_HOST=trading-pooler-ro.data.svc.cluster.local
PG_RO_PORT=5432

PG_DATABASE=trading
