{
  "title": "k3d Stats",
  "uid": "9mfU3p-vk",
  "schemaVersion": 34,
  "refresh": "5s",
  "panels": [
    {
      "id": 6,
      "title": "FastAPI Live Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "loki-local" },
      "options": {
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": true,
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki-local" },
          "expr": "{app=\"booklib\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active FastAPI Nodes",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom-local" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prom-local" },
          "expr": "count(group by (pod) (container_cpu_usage_seconds_total{namespace=\"backend\", container=\"fastapi\"}))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "FastAPI CPU Usage ",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 20, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom-local" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2
          },
          "unit": "cores"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prom-local" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"backend\", container=\"fastapi\"}[1m])) by (pod)",
          "refId": "A"
        }
      ]
    }
  ]
}
